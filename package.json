{
  "name": "skill-tree-chopper",
  "displayName": "Skill Tree Chopper",
  "description": "A VS Code extension to audit, disable, or delete AI skill directories.",
  "version": "1.0.1",
  "publisher": "LuminairPrime",
  "icon": "resources/icons/skill-tree-chopper-icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/LuminairPrime/skill-tree-chopper.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:aiSkillAuditor"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "aiSkillAuditorContainer",
          "title": "Skill Tree Chopper",
          "icon": "try7.svg"
        }
      ]
    },
    "views": {
      "aiSkillAuditorContainer": [
        {
          "id": "aiSkillAuditor",
          "name": "Skill Tree Chopper"
        }
      ]
    },
    "commands": [
      {
        "command": "aiSkills.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "aiSkills.deleteSkill",
        "title": "Delete Skill",
        "icon": "$(trash)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "aiSkills.refresh",
          "when": "view == aiSkillAuditor",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "aiSkills.deleteSkill",
          "when": "view == aiSkillAuditor && viewItem == skillFolder",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm.cmd run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "shx": "^0.4.0",
    "typescript": "^5.1.3",
    "vitest": "^3.2.4"
  }
}
